<resources>
    <style name="Theme.Emiscreen" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/emiscreen_primary</item>
        <item name="colorPrimaryDark">@color/emiscreen_background</item>
        <item name="android:windowBackground">@color/emiscreen_background</item>
    </style>

    <style name="Theme.Emiscreen.NoActionBar" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/emiscreen_primary</item>
        <item name="colorPrimaryDark">@color/emiscreen_background</item>
        <item name="android:windowBackground">@color/emiscreen_background</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
